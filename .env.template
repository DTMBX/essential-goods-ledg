# Essential Goods Ledger (Chronos) — Environment Template
# Copy to .env and fill in real values. NEVER commit .env with real credentials.

# Vite public variables (safe to expose in client bundle)
VITE_APP_NAME=Essential Goods Ledger
VITE_APP_URL=https://ledger.xtx396.com

# Federal data proxy (Cloudflare Worker URL)
# When set, all BLS/EIA/USDA calls route through the proxy.
# When unset, clients fall back to direct calls with public demo keys.
# VITE_PROXY_URL=https://federal-data-proxy.<your-account>.workers.dev

# Federal API keys — stored as Cloudflare Worker SECRETS, not here.
# Set via:  cd workers/federal-data-proxy && wrangler secret put BLS_API_KEY
#           cd workers/federal-data-proxy && wrangler secret put EIA_API_KEY
#           cd workers/federal-data-proxy && wrangler secret put USDA_API_KEY
